<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inicio Vending — Premium Outdoor Vending Machines Nederland</title>
  <meta name="description" content="Inicio Vending plaatst premium outdoor vendingmachines op tankstations, wasstraten, laadpleinen en bedrijventerreinen. Geen investering nodig.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --black:#0c0c10;--dark:#1a1a20;--carbon:#222228;
      --red:#e2001a;--red-dark:#c40016;--red-soft:#fff0f1;--red-glow:rgba(226,0,26,.25);
      --white:#ffffff;--cream:#faf9f7;--warm:#f4f2ee;--silver:#e8e7e3;
      --text:#1a1a20;--text-mid:#4a4a56;--text-light:#7a7a88;
      --border:rgba(0,0,0,.06);--radius:16px;--radius-sm:10px;
    }
    html{scroll-behavior:smooth}
    body{font-family:'Outfit',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden;-webkit-font-smoothing:antialiased}

    /* ═══ NAV ═══ */
    nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:18px 48px;display:flex;justify-content:space-between;align-items:center;transition:all .4s}
    nav.scrolled{background:rgba(255,255,255,.97);backdrop-filter:blur(20px);padding:12px 48px;box-shadow:0 1px 20px rgba(0,0,0,.06)}
    .logo{font-family:'Space Grotesk';font-size:1.45rem;font-weight:700;color:var(--white);text-decoration:none;display:flex;align-items:center;gap:2px;transition:color .4s}
    nav.scrolled .logo{color:var(--black)}
    .logo-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--red);margin-left:1px;box-shadow:0 0 10px var(--red-glow)}
    .nav-links{display:flex;gap:32px;list-style:none;align-items:center}
    .nav-links a{color:rgba(255,255,255,.7);text-decoration:none;font-size:.85rem;font-weight:500;transition:color .3s}
    nav.scrolled .nav-links a{color:var(--text-light)}
    .nav-links a:hover{color:var(--white)}
    nav.scrolled .nav-links a:hover{color:var(--red)}
    .nav-cta{background:var(--red)!important;color:var(--white)!important;padding:10px 24px;border-radius:8px;font-weight:600!important;transition:all .3s!important}
    .nav-cta:hover{background:var(--red-dark)!important;transform:translateY(-2px);box-shadow:0 6px 24px var(--red-glow)}
    .mobile-toggle{display:none;background:none;border:none;cursor:pointer;padding:4px}
    .mobile-toggle span{display:block;width:24px;height:2px;background:var(--white);margin:5px 0;transition:.3s}
    nav.scrolled .mobile-toggle span{background:var(--black)}

    /* ═══ HERO ═══ */
    .hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:130px 60px 80px;background:var(--black)}
    .hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(226,0,26,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(226,0,26,.025) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at 35% 50%,black 25%,transparent 70%)}
    .hero-glow{position:absolute;border-radius:50%;filter:blur(150px);pointer-events:none}
    .hero-glow-1{width:600px;height:600px;top:-200px;right:-100px;background:var(--red);opacity:.06}
    .hero-glow-2{width:300px;height:300px;bottom:-80px;left:10%;background:#e8e7e3;opacity:.03}
    .hero-stripe{position:absolute;top:0;left:0;width:4px;height:100%;background:linear-gradient(180deg,transparent,var(--red),transparent);opacity:.3}
    .hero-content{max-width:1360px;margin:0 auto;width:100%;display:grid;grid-template-columns:1.15fr .85fr;gap:72px;align-items:center;position:relative;z-index:2}
    .hero-tag{display:inline-flex;align-items:center;gap:10px;background:rgba(226,0,26,.08);border:1px solid rgba(226,0,26,.18);padding:7px 18px;border-radius:6px;font-size:.7rem;font-weight:700;color:var(--red);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:24px;animation:fadeInUp .7s ease both}
    .hero-tag::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%;box-shadow:0 0 10px var(--red-glow);animation:pulse 2s ease infinite}
    @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 10px var(--red-glow)}50%{opacity:.5;box-shadow:0 0 20px var(--red-glow)}}
    .hero h1{font-size:clamp(2.6rem,5.2vw,4.4rem);font-weight:800;line-height:1.06;margin-bottom:22px;letter-spacing:-1px;color:var(--white);animation:fadeInUp .7s ease .1s both}
    .hl{background:linear-gradient(135deg,var(--red),#ff2d3a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hl-s{color:var(--red)}
    .hero-text{font-size:1.08rem;line-height:1.75;color:rgba(255,255,255,.55);max-width:520px;margin-bottom:28px;animation:fadeInUp .7s ease .2s both}
    .hero-trust{display:flex;align-items:center;gap:24px;margin-bottom:36px;animation:fadeInUp .7s ease .25s both}
    .hero-trust-item{display:flex;align-items:center;gap:8px;font-size:.82rem;color:rgba(255,255,255,.5)}
    .hero-actions{display:flex;gap:14px;flex-wrap:wrap;animation:fadeInUp .7s ease .3s both}
    .btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;border-radius:10px;font-family:'Outfit';font-size:.92rem;font-weight:600;text-decoration:none;cursor:pointer;border:none;transition:all .35s ease}
    .btn-primary{background:var(--red);color:var(--white);box-shadow:0 4px 24px var(--red-glow)}
    .btn-primary:hover{transform:translateY(-3px);box-shadow:0 10px 36px var(--red-glow);background:var(--red-dark)}
    .btn-outline-w{background:transparent;color:var(--white);border:1.5px solid rgba(255,255,255,.2)}
    .btn-outline-w:hover{border-color:var(--red);color:var(--red);transform:translateY(-3px)}

    /* Hero Visual */
    .hero-visual{position:relative;animation:fadeInUp .7s ease .4s both}
    .machine-showcase{background:linear-gradient(160deg,var(--dark),var(--carbon));border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:36px 28px;position:relative;overflow:hidden}
    .machine-showcase::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),transparent 60%)}
    .ms-label{font-size:.68rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--red);margin-bottom:14px}
    .machine-showcase h3{font-family:'Space Grotesk';font-size:1.45rem;font-weight:700;color:var(--white);margin-bottom:4px}
    .ms-sub{color:rgba(255,255,255,.45);font-size:.88rem;margin-bottom:22px}
    .machine-specs{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .spec-item{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.04);border-radius:var(--radius-sm);padding:14px}
    .spec-val{font-family:'Space Grotesk';font-size:1.2rem;font-weight:700;color:var(--white)}
    .spec-val.red{color:var(--red)}
    .spec-lbl{font-size:.68rem;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.8px;margin-top:3px}
    .floating-tag{position:absolute;background:var(--white);color:var(--black);border-radius:10px;padding:11px 16px;display:flex;align-items:center;gap:9px;box-shadow:0 12px 40px rgba(0,0,0,.5);font-weight:600;font-size:.8rem;animation:float 4s ease-in-out infinite}
    .floating-tag-1{top:-14px;right:-14px}
    .floating-tag-2{bottom:50px;left:-22px;animation-delay:2s}
    .tdot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
    .tdot-r{background:var(--red);box-shadow:0 0 8px var(--red-glow)}
    .tdot-g{background:#00c853;box-shadow:0 0 8px rgba(0,200,83,.4)}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
    @keyframes fadeInUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

    /* ═══ MARQUEE ═══ */
    .marquee{background:var(--red);padding:14px 0;overflow:hidden}
    .marquee-track{display:flex;width:max-content;animation:marq 22s linear infinite}
    .marquee-item{font-size:.82rem;font-weight:700;color:var(--white);white-space:nowrap;padding:0 32px;display:flex;align-items:center;gap:10px;text-transform:uppercase;letter-spacing:1.2px}
    .marquee-item::before{content:'◆';font-size:.35rem;opacity:.45}
    @keyframes marq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    /* ═══ STATS ═══ */
    .stats-bar{padding:48px 60px;background:var(--white);border-bottom:1px solid var(--border)}
    .stats-inner{max-width:1360px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:24px;text-align:center}
    .stat-val{font-family:'Space Grotesk';font-size:2rem;font-weight:700;color:var(--black);line-height:1}
    .stat-val span{color:var(--red)}
    .stat-lbl{font-size:.72rem;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-top:6px}

    /* ═══ SECTION HELPERS ═══ */
    .section-label{display:inline-flex;align-items:center;gap:12px;font-size:.7rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--red);margin-bottom:18px}
    .section-label::before{content:'';width:22px;height:2px;background:var(--red)}
    .section-label-center{justify-content:center;display:flex}
    h2.section-title{font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:800;line-height:1.1;letter-spacing:-.5px;color:var(--black)}
    h2.section-title.center{text-align:center}
    .section-sub{color:var(--text-mid);font-size:1rem;line-height:1.7}
    .section-sub.center{text-align:center;max-width:600px;margin-left:auto;margin-right:auto}

    /* ═══ ABOUT ═══ */
    .about{padding:110px 60px;max-width:1360px;margin:0 auto}
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start}
    .about-text{font-size:1rem;line-height:1.8;color:var(--text-mid);margin-top:22px}

    /* Feature cards — red left border, no emoji */
    .about-features{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .feat{background:var(--white);border:1px solid var(--border);border-left:3px solid var(--red);border-radius:2px var(--radius-sm) var(--radius-sm) 2px;padding:22px 24px;transition:all .35s}
    .feat:hover{transform:translateY(-3px);box-shadow:0 10px 32px rgba(0,0,0,.05)}
    .feat h4{font-weight:700;font-size:.9rem;margin-bottom:4px;color:var(--black)}
    .feat p{font-size:.82rem;color:var(--text-light);line-height:1.55}

    /* ═══ USP — numbered horizontal layout ═══ */
    .usp{padding:110px 60px;background:var(--red-soft)}
    .usp-inner{max-width:1360px;margin:0 auto}
    .usp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:56px}
    .usp-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:32px 28px;transition:all .4s;position:relative}
    .usp-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.06)}
    .usp-num{font-family:'Space Grotesk';font-size:2.4rem;font-weight:700;color:var(--red);opacity:.15;position:absolute;top:16px;right:20px;line-height:1}
    .usp-card h4{font-weight:700;font-size:1rem;color:var(--black);margin-bottom:8px;padding-right:40px}
    .usp-card p{color:var(--text-mid);font-size:.88rem;line-height:1.6}

    /* ═══ PRODUCT ═══ */
    .product{padding:110px 60px;background:var(--white)}
    .product-inner{max-width:1360px;margin:0 auto}
    .product-sub{margin-top:14px;margin-bottom:56px}
    .product-main{display:grid;grid-template-columns:1fr 1fr;gap:36px}
    .pv{background:linear-gradient(160deg,var(--black),var(--dark));border:1px solid rgba(255,255,255,.05);border-radius:20px;padding:48px;display:flex;align-items:center;justify-content:center;position:relative;min-height:420px}
    .pv::before{content:'';position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(to top,rgba(226,0,26,.03),transparent);border-radius:0 0 20px 20px}
    .mach{position:relative;z-index:2;text-align:center}
    .mach-body{width:170px;height:310px;background:linear-gradient(180deg,#28282e,#1c1c22);border:2px solid rgba(255,255,255,.07);border-radius:12px;margin:0 auto;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.5),inset 0 1px 0 rgba(255,255,255,.04)}
    .mach-housing{position:absolute;inset:-11px;border:3px solid #b8b8c4;border-radius:15px;box-shadow:0 0 24px rgba(192,192,200,.04)}
    .mach-screen{width:132px;height:92px;background:linear-gradient(135deg,#0d47a1,#1565c0,var(--red));border-radius:5px;margin:18px auto 0;position:relative;box-shadow:0 0 18px rgba(226,0,26,.15)}
    .mach-screen::after{content:'22″ TOUCH';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Space Grotesk';font-size:.7rem;font-weight:700;color:var(--white);letter-spacing:1.5px}
    .mach-grid{width:132px;height:136px;margin:10px auto 0;background:rgba(0,0,0,.35);border-radius:4px;display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(5,1fr);gap:2px;padding:6px}
    .mach-slot{background:rgba(255,255,255,.05);border-radius:2px}
    .mach-slot:nth-child(odd){background:rgba(226,0,26,.06)}
    .mach-label{position:absolute;bottom:-30px;left:50%;transform:translateX(-50%);font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.4);white-space:nowrap}

    /* Product details — numbered, no emoji */
    .pd{display:flex;flex-direction:column;justify-content:center}
    .pd-item{padding:22px 0;border-bottom:1px solid var(--border);display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:start}
    .pd-item:last-child{border-bottom:none}
    .pd-num{font-family:'Space Grotesk';font-size:.7rem;font-weight:700;color:var(--white);background:var(--red);width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
    .pd-item h4{font-family:'Space Grotesk';font-size:1.05rem;font-weight:700;color:var(--black);margin-bottom:4px}
    .pd-item p{color:var(--text-mid);font-size:.88rem;line-height:1.6}

    /* ═══ LOCATIONS — icon replaced with red accent + bold type ═══ */
    .locations{padding:110px 60px;background:var(--cream)}
    .loc-inner{max-width:1360px;margin:0 auto}
    .loc-sub{margin-bottom:56px;margin-top:14px}
    .loc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .loc-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:0;text-align:left;transition:all .4s;position:relative;overflow:hidden}
    .loc-card-top{height:6px;background:var(--red)}
    .loc-card-body{padding:28px 24px}
    .loc-card:hover{transform:translateY(-5px);box-shadow:0 14px 44px rgba(0,0,0,.06)}
    .loc-card h4{font-weight:700;font-size:1.1rem;color:var(--black);margin-bottom:8px}
    .loc-card p{color:var(--text-light);font-size:.85rem;line-height:1.55}

    /* ═══ PROCESS ═══ */
    .process{padding:110px 60px;background:var(--white)}
    .proc-inner{max-width:1360px;margin:0 auto}
    .proc-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;margin-top:64px}
    .proc-steps::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:2px;background:linear-gradient(90deg,var(--red),var(--silver),var(--red),var(--silver),var(--red))}
    .proc-step{text-align:center;position:relative;padding:0 12px}
    .step-n{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-family:'Space Grotesk';font-size:1rem;font-weight:700;position:relative;z-index:2;border:2px solid var(--silver);background:var(--white);color:var(--text-light)}
    .s1 .step-n,.s3 .step-n,.s5 .step-n{background:var(--red);border-color:var(--red);color:var(--white);box-shadow:0 0 20px var(--red-glow)}
    .proc-step h4{font-size:.92rem;font-weight:700;color:var(--black);margin-bottom:6px}
    .proc-step p{font-size:.8rem;color:var(--text-light);line-height:1.5}

    /* ═══ TESTIMONIALS ═══ */
    .testi{padding:110px 60px;background:var(--cream)}
    .testi-inner{max-width:1360px;margin:0 auto}
    .testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:56px}
    .testi-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:32px;position:relative}
    .testi-card::before{content:'';position:absolute;top:0;left:28px;width:40px;height:3px;background:var(--red);border-radius:0 0 2px 2px}
    .testi-quote{color:var(--text-mid);font-size:.92rem;line-height:1.65;margin-bottom:20px;font-style:italic;padding-top:12px}
    .testi-author{display:flex;align-items:center;gap:12px;border-top:1px solid var(--border);padding-top:16px}
    .testi-avatar{width:40px;height:40px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:var(--white)}
    .testi-name{font-weight:600;font-size:.88rem;color:var(--black)}
    .testi-role{font-size:.75rem;color:var(--text-light)}

    /* ═══ FAQ ═══ */
    .faq{padding:110px 60px;background:var(--white)}
    .faq-inner{max-width:800px;margin:0 auto}
    .faq-item{border-bottom:1px solid var(--border);overflow:hidden}
    .faq-q{width:100%;background:none;border:none;color:var(--black);font-family:'Outfit';font-size:1rem;font-weight:600;padding:20px 0;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:color .3s}
    .faq-q:hover{color:var(--red)}
    .faq-q .faq-icon{width:28px;height:28px;border-radius:6px;background:var(--warm);display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0;margin-left:16px}
    .faq-q .faq-icon svg{transition:transform .3s;color:var(--text-light)}
    .faq-item.open .faq-q .faq-icon{background:var(--red)}
    .faq-item.open .faq-q .faq-icon svg{transform:rotate(45deg);color:var(--white)}
    .faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .4s ease;color:var(--text-mid);font-size:.9rem;line-height:1.7}
    .faq-item.open .faq-a{max-height:200px;padding-bottom:20px}

    /* ═══ LEADS ═══ */
    .leads{padding:110px 60px;position:relative;overflow:hidden}
    .leads-bg{position:absolute;inset:0;background:linear-gradient(135deg,var(--red-dark),var(--red),#cc0015)}
    .leads-tex{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.04) 1px,transparent 1px);background-size:28px 28px}
    .leads-cf{position:absolute;inset:0;opacity:.1;background:linear-gradient(45deg,transparent 25%,rgba(0,0,0,.1) 25%,rgba(0,0,0,.1) 50%,transparent 50%,transparent 75%,rgba(0,0,0,.1) 75%);background-size:4px 4px}
    .leads-inner{max-width:880px;margin:0 auto;position:relative;z-index:2}
    .leads h2{font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:800;color:var(--white);text-align:center;margin-bottom:10px}
    .leads-sub{text-align:center;color:rgba(255,255,255,.78);font-size:1rem;margin-bottom:44px}
    .lead-form{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:44px;backdrop-filter:blur(14px)}
    .fg{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
    .fi{display:flex;flex-direction:column}
    .fi.full{grid-column:1/-1}
    .fi label{color:rgba(255,255,255,.85);font-size:.8rem;font-weight:600;margin-bottom:5px}
    .fi input,.fi textarea,.fi select{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.18);border-radius:var(--radius-sm);padding:13px 16px;color:var(--white);font-family:'Outfit';font-size:.9rem;transition:all .3s;outline:none}
    .fi input::placeholder,.fi textarea::placeholder{color:rgba(255,255,255,.35)}
    .fi input:focus,.fi textarea:focus,.fi select:focus{border-color:var(--white);background:rgba(255,255,255,.18)}
    .fi select option{background:var(--black)}
    .fi textarea{resize:vertical;min-height:90px}
    .form-btn{width:100%;padding:16px;background:var(--white);color:var(--red);font-family:'Outfit';font-size:.95rem;font-weight:800;border:none;border-radius:10px;cursor:pointer;transition:all .35s;letter-spacing:.5px;text-transform:uppercase}
    .form-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.25)}

    /* ═══ CONTACT — clean, no emoji ═══ */
    .contact{padding:90px 60px;background:var(--cream)}
    .contact-inner{max-width:1360px;margin:0 auto}
    .con-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;max-width:700px;margin-left:auto;margin-right:auto;margin-top:56px}
    .con-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:32px;text-align:center;transition:all .35s}
    .con-card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(0,0,0,.06)}
    .con-card-label{font-size:.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:12px}
    .con-card h4{font-weight:700;margin-bottom:4px;color:var(--black);font-size:1.05rem}
    .con-card p{color:var(--text-light);font-size:.88rem;line-height:1.6}
    .con-card a{color:var(--red);text-decoration:none;font-weight:600}

    /* ═══ FOOTER ═══ */
    footer{background:var(--black);padding:44px 60px;text-align:center}
    .ft-brand{font-family:'Space Grotesk';font-size:1.4rem;font-weight:700;color:var(--white);margin-bottom:14px;display:flex;align-items:center;justify-content:center;gap:2px}
    .ft-links{display:flex;justify-content:center;gap:28px;list-style:none;margin:16px 0}
    .ft-links a{color:rgba(255,255,255,.4);text-decoration:none;font-size:.82rem;transition:color .3s}
    .ft-links a:hover{color:var(--red)}
    footer p{color:rgba(255,255,255,.2);font-size:.78rem}

    /* ═══ ANIMATIONS ═══ */
    .reveal{opacity:0;transform:translateY(32px);transition:all .7s cubic-bezier(.16,1,.3,1)}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* ═══ RESPONSIVE ═══ */
    @media(max-width:1100px){
      .hero-content{grid-template-columns:1fr;gap:48px}
      .about-grid{grid-template-columns:1fr;gap:48px}
      .product-main{grid-template-columns:1fr}
      .loc-grid{grid-template-columns:1fr 1fr}
      .proc-steps{grid-template-columns:repeat(3,1fr);gap:28px}
      .proc-steps::before{display:none}
      .testi-grid{grid-template-columns:1fr}
      .usp-grid{grid-template-columns:1fr 1fr}
      .stats-inner{grid-template-columns:repeat(3,1fr)}
    }
    @media(max-width:768px){
      .hero{padding:110px 24px 60px}
      .about,.usp,.product,.locations,.process,.testi,.faq,.leads,.contact{padding:80px 24px}
      .stats-bar{padding:36px 24px}
      nav{padding:14px 20px}
      .nav-links{display:none}
      .mobile-toggle{display:block}
      .loc-grid,.usp-grid{grid-template-columns:1fr}
      .con-grid{grid-template-columns:1fr}
      .proc-steps{grid-template-columns:1fr 1fr}
      .about-features{grid-template-columns:1fr}
      .fg{grid-template-columns:1fr}
      .lead-form{padding:28px 20px}
      .floating-tag{display:none}
      .machine-specs{grid-template-columns:1fr}
      .hero-trust{flex-direction:column;align-items:flex-start;gap:10px}
      .stats-inner{grid-template-columns:repeat(2,1fr)}
    }
    @media(max-width:480px){
      .hero-actions{flex-direction:column}
      .btn{width:100%;justify-content:center}
      .proc-steps{grid-template-columns:1fr}
      .stats-inner{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>

<nav id="navbar">
  <a href="#" class="logo">inicio<span class="logo-dot"></span></a>
  <ul class="nav-links">
    <li><a href="#about">Over Ons</a></li>
    <li><a href="#product">Onze Machine</a></li>
    <li><a href="#locaties">Locaties</a></li>
    <li><a href="#werkwijze">Werkwijze</a></li>
    <li><a href="#faq">FAQ</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="#leads" class="nav-cta">Gratis Locatiecheck</a></li>
  </ul>
  <button class="mobile-toggle" onclick="document.querySelector('.nav-links').classList.toggle('show')"><span></span><span></span><span></span></button>
</nav>

<section class="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>
  <div class="hero-stripe"></div>
  <div class="hero-content">
    <div>
      <div class="hero-tag">Premium Outdoor Vending</div>
      <h1>Extra omzet op uw locatie. <span class="hl">Zonder investering.</span></h1>
      <p class="hero-text">Inicio Vending plaatst en exploiteert premium vendingmachines met 22" touchscreen en robuuste outdoor ombouw. U stelt de locatie beschikbaar — wij doen de rest.</p>
      <div class="hero-trust">
        <div class="hero-trust-item"><svg width="16" height="16" fill="#e2001a" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Geen investering nodig</div>
        <div class="hero-trust-item"><svg width="16" height="16" fill="#e2001a" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>24/7 service & monitoring</div>
        <div class="hero-trust-item"><svg width="16" height="16" fill="#e2001a" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Binnen 24 uur reactie</div>
      </div>
      <div class="hero-actions">
        <a href="#leads" class="btn btn-primary">Plan gratis locatiecheck <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        <a href="#product" class="btn btn-outline-w">Bekijk onze machine</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="machine-showcase">
        <div class="ms-label">Flagship Machine</div>
        <h3>Inicio Vendingmachine</h3>
        <p class="ms-sub">22" schermopbouw · premium outdoor ombouw</p>
        <div class="machine-specs">
          <div class="spec-item"><div class="spec-val red">22"</div><div class="spec-lbl">Touchscreen</div></div>
          <div class="spec-item"><div class="spec-val">Full</div><div class="spec-lbl">Service</div></div>
          <div class="spec-item"><div class="spec-val red">24/7</div><div class="spec-lbl">Outdoor Ready</div></div>
          <div class="spec-item"><div class="spec-val">100%</div><div class="spec-lbl">Cashless</div></div>
        </div>
      </div>
      <div class="floating-tag floating-tag-1"><span class="tdot tdot-r"></span>Contactloos betalen</div>
      <div class="floating-tag floating-tag-2"><span class="tdot tdot-g"></span>Vandaalbestendig</div>
    </div>
  </div>
</section>

<div class="marquee">
  <div class="marquee-track">
    <span class="marquee-item">Tankstations</span><span class="marquee-item">Bedrijventerreinen</span><span class="marquee-item">Wasstraten</span><span class="marquee-item">Laadpleinen</span><span class="marquee-item">Parkeerterreinen</span><span class="marquee-item">Industrieterreinen</span><span class="marquee-item">Dealerlocaties</span><span class="marquee-item">P+R Terreinen</span>
    <span class="marquee-item">Tankstations</span><span class="marquee-item">Bedrijventerreinen</span><span class="marquee-item">Wasstraten</span><span class="marquee-item">Laadpleinen</span><span class="marquee-item">Parkeerterreinen</span><span class="marquee-item">Industrieterreinen</span><span class="marquee-item">Dealerlocaties</span><span class="marquee-item">P+R Terreinen</span>
  </div>
</div>

<div class="stats-bar reveal">
  <div class="stats-inner">
    <div class="stat-item"><div class="stat-val"><span>24</span>/7</div><div class="stat-lbl">Beschikbaar</div></div>
    <div class="stat-item"><div class="stat-val">100<span>%</span></div><div class="stat-lbl">Cashless</div></div>
    <div class="stat-item"><div class="stat-val"><span>0</span>€</div><div class="stat-lbl">Investering</div></div>
    <div class="stat-item"><div class="stat-val">Real<span>time</span></div><div class="stat-lbl">Monitoring</div></div>
    <div class="stat-item"><div class="stat-val">22<span>"</span></div><div class="stat-lbl">Touchscreen</div></div>
  </div>
</div>

<section class="about" id="about">
  <div class="about-grid">
    <div class="reveal">
      <div class="section-label">Over Inicio Vending</div>
      <h2 class="section-title">Premium outdoor vending, <span class="hl">volledig ontzorgd</span></h2>
      <p class="about-text">Inicio Vending is gespecialiseerd in het plaatsen en exploiteren van premium outdoor vendingmachines op drukbezochte locaties in Nederland.<br><br>In tegenstelling tot standaard automaatverhuur investeren wij volledig in de machine, installatie en exploitatie. U stelt enkel een geschikte locatie beschikbaar en deelt mee in de omzet. Wij regelen het complete beheer — van assortiment en bevoorrading tot realtime monitoring, onderhoud en klantenservice.<br><br>Onze vendingmachine met 22" schermopbouw en robuuste outdoor ombouw onderscheidt zich door premium uitstraling, weersbestendigheid en maximale uptime.</p>
    </div>
    <div class="about-features reveal">
      <div class="feat"><h4>Outdoor ombouw</h4><p>Robuuste behuizing voor weersbestendigheid, stevigheid en premium uitstraling op elke buitenlocatie.</p></div>
      <div class="feat"><h4>22" touchscreen</h4><p>Interactief display voor productselectie, promoties en advertentiemogelijkheden op maat.</p></div>
      <div class="feat"><h4>100% cashless</h4><p>Pin, contactloos en mobiel betalen. Geen contant geld, geen risico, geen gedoe.</p></div>
      <div class="feat"><h4>Realtime monitoring</h4><p>Continue controle op voorraad, temperatuur en storingen voor maximale uptime.</p></div>
    </div>
  </div>
</section>

<section class="usp">
  <div class="usp-inner">
    <div class="reveal">
      <div class="section-label section-label-center">Waarom Inicio Vending</div>
      <h2 class="section-title center">Samenwerken met Inicio betekent</h2>
      <p class="section-sub center" style="margin-top:16px">Wij zorgen voor alles. U profiteert van extra omzet en service voor uw bezoekers.</p>
    </div>
    <div class="usp-grid reveal">
      <div class="usp-card"><span class="usp-num">01</span><h4>Geen investering nodig</h4><p>Wij investeren volledig in machine, installatie en beheer. U maakt geen kosten.</p></div>
      <div class="usp-card"><span class="usp-num">02</span><h4>Volledig ontzorgd</h4><p>Van plaatsing tot bevoorrading, onderhoud en klantenservice — wij regelen alles.</p></div>
      <div class="usp-card"><span class="usp-num">03</span><h4>Datagedreven optimalisatie</h4><p>Wij analyseren verkoopdata om assortiment en prestaties continu te verbeteren.</p></div>
      <div class="usp-card"><span class="usp-num">04</span><h4>Deel mee in de omzet</h4><p>U ontvangt een eerlijke vergoeding per verkoop. Structurele extra inkomsten.</p></div>
      <div class="usp-card"><span class="usp-num">05</span><h4>Altijd beschikbaar</h4><p>24/7 open, 365 dagen per jaar. Uw bezoekers kunnen altijd terecht.</p></div>
      <div class="usp-card"><span class="usp-num">06</span><h4>A-merk assortiment</h4><p>Breed aanbod met bekende merken, afgestemd op uw locatie en doelgroep.</p></div>
    </div>
  </div>
</section>

<section class="product" id="product">
  <div class="product-inner">
    <div class="reveal">
      <div class="section-label">Onze Machine</div>
      <h2 class="section-title">De Inicio <span class="hl">Vendingmachine</span></h2>
      <p class="section-sub product-sub">Ons paradepaardje: een krachtige vendingmachine met premium 22" schermopbouw en robuuste outdoor ombouw. Gebouwd om buiten te presteren.</p>
    </div>
    <div class="product-main reveal">
      <div class="pv">
        <div class="mach">
          <div class="mach-body">
            <div class="mach-housing"></div>
            <div class="mach-screen"></div>
            <div class="mach-grid">
              <div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div>
              <div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div>
              <div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div>
              <div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div>
              <div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div><div class="mach-slot"></div>
            </div>
            <div class="mach-label">Premium Outdoor Ombouw</div>
          </div>
        </div>
      </div>
      <div class="pd">
        <div class="pd-item"><div class="pd-num">1</div><div><h4>Betrouwbaar Platform</h4><p>Bewezen technologie met energiezuinige koeling, hoge capaciteit en maximale betrouwbaarheid.</p></div></div>
        <div class="pd-item"><div class="pd-num">2</div><div><h4>22" Interactief Touchscreen</h4><p>Groot display voor intuïtieve productselectie, advertentiecontent en promoties op maat.</p></div></div>
        <div class="pd-item"><div class="pd-num">3</div><div><h4>Premium Outdoor Ombouw</h4><p>Stevige behuizing voor weersbestendigheid en vandaalbestendigheid. Gepoedercoat in gewenste kleur.</p></div></div>
        <div class="pd-item"><div class="pd-num">4</div><div><h4>Smart Telemetrie</h4><p>Realtime monitoring van voorraad, temperatuur en storingen. Proactief onderhoud voor maximale uptime.</p></div></div>
        <div class="pd-item"><div class="pd-num">5</div><div><h4>Cashless Betaalsysteem</h4><p>Pin, contactloos, Apple Pay, Google Pay. Geen contant geld nodig — veilig en snel.</p></div></div>
      </div>
    </div>
  </div>
</section>

<section class="locations" id="locaties">
  <div class="loc-inner">
    <div class="reveal">
      <div class="section-label section-label-center">Doellocaties</div>
      <h2 class="section-title center">Waar Inicio het best <span class="hl">presteert</span></h2>
      <p class="section-sub center loc-sub">Onze machines zijn specifiek ontwikkeld voor buitenlocaties met structurele bezoekersstromen.</p>
    </div>
    <div class="loc-grid reveal">
      <div class="loc-card"><div class="loc-card-top"></div><div class="loc-card-body"><h4>Tankstations</h4><p>Hoge doorstroom met impulsaankopen. Perfecte match voor snacks en koude dranken onderweg.</p></div></div>
      <div class="loc-card"><div class="loc-card-top"></div><div class="loc-card-body"><h4>Bedrijventerreinen</h4><p>Medewerkers en bezoekers op elk moment voorzien van verfrissingen en snacks.</p></div></div>
      <div class="loc-card"><div class="loc-card-top"></div><div class="loc-card-body"><h4>Wasstraten</h4><p>Wachtende klanten converteren naar kopers. Extra omzet tijdens de wasbeurt.</p></div></div>
      <div class="loc-card"><div class="loc-card-top"></div><div class="loc-card-body"><h4>Laadpleinen</h4><p>EV-rijders wachten 20–45 minuten. De ideale kans voor een snack of drankje.</p></div></div>
    </div>
  </div>
</section>

<section class="process" id="werkwijze">
  <div class="proc-inner">
    <div class="reveal">
      <div class="section-label section-label-center">Werkwijze</div>
      <h2 class="section-title center">Van aanvraag tot <span class="hl-s">exploitatie</span></h2>
    </div>
    <div class="proc-steps reveal">
      <div class="proc-step s1"><div class="step-n">01</div><h4>Locatiecheck</h4><p>Wij beoordelen uw locatie op doorstroom, zichtbaarheid en aansluitmogelijkheden.</p></div>
      <div class="proc-step s2"><div class="step-n">02</div><h4>Maatwerkvoorstel</h4><p>U ontvangt een plan met machineconfig en assortiment op maat.</p></div>
      <div class="proc-step s3"><div class="step-n">03</div><h4>Installatie</h4><p>Ons team plaatst de machine, aansluiting op 220V, internet en betaalsysteem.</p></div>
      <div class="proc-step s4"><div class="step-n">04</div><h4>Bevoorrading</h4><p>Wij vullen de machine regelmatig bij op basis van realtime voorraaddata.</p></div>
      <div class="proc-step s5"><div class="step-n">05</div><h4>24/7 Service</h4><p>Continue monitoring, onderhoud en klantenservice. U hoeft niets te doen.</p></div>
    </div>
  </div>
</section>



<section class="faq" id="faq">
  <div class="faq-inner">
    <div class="reveal">
      <div class="section-label section-label-center">Veelgestelde vragen</div>
      <h2 class="section-title center">FAQ</h2>
    </div>
    <div class="reveal" style="margin-top:8px">
      <div class="faq-item"><button class="faq-q">Wat kost het om een Inicio machine te plaatsen?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Niets. Inicio Vending investeert volledig in de machine, installatie, bevoorrading en exploitatie. U maakt geen kosten.</div></div>
      <div class="faq-item"><button class="faq-q">Hoe verdien ik als partner?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">U ontvangt een maandelijkse omzetvergoeding op basis van de verkopen. Hoe meer er verkocht wordt, hoe meer u verdient.</div></div>
      <div class="faq-item"><button class="faq-q">Welke ruimte is nodig?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">De machine met ombouw vraagt een oppervlak van circa 1 x 1,5 meter. Verder is een 220V aansluiting en internetverbinding nodig.</div></div>
      <div class="faq-item"><button class="faq-q">Wie regelt de bevoorrading?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Wij verzorgen de volledige bevoorrading op basis van realtime voorraaddata. U hoeft niets te doen.</div></div>
      <div class="faq-item"><button class="faq-q">Wie is verantwoordelijk bij storingen?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Inicio Vending. Onze machines worden 24/7 op afstand gemonitord en bij storingen sturen wij direct een monteur.</div></div>
      <div class="faq-item"><button class="faq-q">Wat gebeurt er bij vandalisme of schade?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Onze outdoor ombouw is vandaalbestendig. Bij schade regelen wij reparatie of vervanging — dat risico ligt bij ons.</div></div>
      <div class="faq-item"><button class="faq-q">Kan het assortiment aangepast worden?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Ja. Wij stemmen het assortiment af op uw locatie en doelgroep op basis van verkoopdata en voorkeur.</div></div>
      <div class="faq-item"><button class="faq-q">Hoe snel kan een machine geplaatst worden?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Na goedkeuring van de locatiecheck kan een machine doorgaans binnen 2–4 weken geplaatst worden.</div></div>
      <div class="faq-item"><button class="faq-q">Is stroom of internet nodig?<span class="faq-icon"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></span></button><div class="faq-a">Ja. Een 220V stroomaansluiting is vereist. Voor internet kan een vaste verbinding of een 4G-module gebruikt worden.</div></div>
    </div>
  </div>
</section>

<section class="leads" id="leads">
  <div class="leads-bg"></div>
  <div class="leads-tex"></div>
  <div class="leads-cf"></div>
  <div class="leads-inner">
    <div class="reveal">
      <h2>Gratis locatiecheck. Geen investering. Wel extra omzet.</h2>
      <p class="leads-sub">Ontdek vrijblijvend wat Inicio Vending voor uw locatie kan betekenen.</p>
    </div>
    <div class="lead-form reveal">
      <div class="fg">
        <div class="fi"><label>Naam *</label><input type="text" placeholder="Uw volledige naam"></div>
        <div class="fi"><label>Bedrijf *</label><input type="text" placeholder="Bedrijfsnaam"></div>
        <div class="fi"><label>E-mail *</label><input type="email" placeholder="naam@bedrijf.nl"></div>
        <div class="fi"><label>Telefoon</label><input type="tel" placeholder="+31 6 12345678"></div>
        <div class="fi"><label>Type locatie</label><select><option value="">Selecteer...</option><option>Tankstation</option><option>Bedrijventerrein</option><option>Wasstraat</option><option>Laadplein / EV-charging</option><option>Parkeerterrein / P+R</option><option>Industrieterrein</option><option>Anders</option></select></div>
        <div class="fi"><label>Geschat dagelijks bezoekersaantal</label><select><option value="">Selecteer...</option><option>0 – 100</option><option>100 – 500</option><option>500 – 1.000</option><option>1.000+</option></select></div>
        <div class="fi full"><label>Bericht (optioneel)</label><textarea placeholder="Vertel ons over uw locatie of stel een vraag..."></textarea></div>
      </div>
      <button class="form-btn" onclick="handleSubmit(this)">Plan mijn gratis locatiecheck →</button>
    </div>
  </div>
</section>

<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="reveal">
      <div class="section-label section-label-center">Contact</div>
      <h2 class="section-title center">Neem <span class="hl-s">contact</span> op</h2>
    </div>
    <div class="con-grid reveal">
      <div class="con-card"><div class="con-card-label">Telefoon</div><h4><a href="tel:+31201234567">+31 (0)20 123 4567</a></h4><p>Ma–Vr: 08:00 – 18:00</p></div>
      <div class="con-card"><div class="con-card-label">E-mail</div><h4><a href="mailto:info@iniciovending.nl">info@iniciovending.nl</a></h4><p>Reactie binnen 24 uur</p></div>
    
    </div>
  </div>
</section>

<footer>
  <div class="ft-brand">inicio<span class="logo-dot"></span></div>
  <ul class="ft-links">
    <li><a href="#about">Over Ons</a></li>
    <li><a href="#product">Onze Machine</a></li>
    <li><a href="#locaties">Locaties</a></li>
    <li><a href="#leads">Locatiecheck</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <p>© 2026 Inicio Vending. Alle rechten voorbehouden.</p>
</footer>

<script>
const nav=document.getElementById('navbar');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>50));

const reveals=document.querySelectorAll('.reveal');
const obs=new IntersectionObserver(entries=>{entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*50);obs.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -20px 0px'});
reveals.forEach(el=>obs.observe(el));

document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{e.preventDefault();const t=document.querySelector(a.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth',block:'start'})})});

document.querySelectorAll('.faq-q').forEach(btn=>{btn.addEventListener('click',()=>{const item=btn.parentElement;const was=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));if(!was)item.classList.add('open')})});

function handleSubmit(btn){btn.textContent='✓ Aanvraag verzonden!';btn.style.background='#00c853';btn.style.color='#fff';setTimeout(()=>{btn.textContent='Plan mijn gratis locatiecheck →';btn.style.background='';btn.style.color=''},3000)}
</script>

</body>
</html>
